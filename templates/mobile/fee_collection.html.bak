{% extends 'mobile/base.html' %}
{% load fee_extras %}
{% block title %}Fee Collection | {{ tenant.name }}{% endblock %}

{% block extra_head %}
<style>
    /* ----- custom styles for mobile fee collection ----- */
    .fee-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .fee-header h1 {
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0;
    }
    .fee-header .header-stats {
        display: flex;
        gap: 0.5rem;
        font-size: 0.8rem;
        background: var(--surface);
        padding: 0.3rem 0.8rem;
        border-radius: 2rem;
        border: 1px solid var(--border);
        color: var(--muted);
    }
    .fee-header .header-stats strong {
        color: var(--text);
    }

    /* Search & Filters */
    .search-bar {
        background: var(--surface);
        border-radius: 1.25rem;
        padding: 0.6rem 1rem;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        margin-bottom: 0.75rem;
        border: 1px solid var(--border);
    }
    .search-bar input {
        border: none;
        background: transparent;
        width: 100%;
        font-size: 0.95rem;
        color: var(--text);
        outline: none;
    }
    .search-bar button {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 999px;
        padding: 0.4rem 0.8rem;
        font-weight: 600;
        cursor: pointer;
        flex-shrink: 0;
    }
    .filter-chips {
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        padding-bottom: 0.25rem;
        margin-bottom: 0.75rem;
        -webkit-overflow-scrolling: touch;
    }
    .filter-chips select {
        padding: 0.4rem 0.6rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface);
        font-size: 0.8rem;
        color: var(--text);
        flex-shrink: 0;
    }
    .filter-chips .chip-clear {
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.3rem 0.7rem;
        font-size: 0.8rem;
        color: var(--muted);
        cursor: pointer;
        flex-shrink: 0;
    }

    /* Student List */
    .student-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 1rem;
        background: var(--surface);
        border-radius: 1.25rem;
        margin-bottom: 0.6rem;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        transition: transform 0.15s;
    }
    .student-item:active {
        transform: scale(0.98);
    }
    .student-item .info {
        flex: 1;
        min-width: 0;
    }
    .student-item .info .name {
        font-weight: 700;
        font-size: 1rem;
    }
    .student-item .info .meta {
        font-size: 0.8rem;
        color: var(--muted);
        margin-top: 0.1rem;
    }
    .student-item .info .pending {
        font-weight: 700;
        color: var(--danger);
        font-size: 0.9rem;
    }
    .student-item .collect-btn {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 2rem;
        padding: 0.4rem 1rem;
        font-weight: 600;
        cursor: pointer;
        flex-shrink: 0;
        font-size: 0.85rem;
    }

    /* Detail View */
    .student-detail-card {
        background: var(--surface);
        border-radius: 1.5rem;
        padding: 1rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
    }
    .student-detail-card .name-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .student-detail-card .name-row h2 {
        font-size: 1.2rem;
        margin: 0;
    }
    .student-detail-card .name-row .roll {
        color: var(--muted);
        font-weight: 400;
        font-size: 0.9rem;
    }
    .student-detail-card .detail-meta {
        font-size: 0.85rem;
        color: var(--muted);
        margin-top: 0.3rem;
    }
    .student-detail-card .pending-total {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--danger);
        margin-top: 0.5rem;
    }

    /* Payment Form */
    .payment-form {
        background: var(--surface);
        border-radius: 1.5rem;
        padding: 1rem;
        margin-bottom: 1rem;
        border: 1px solid var(--border);
    }
    .payment-form .form-row {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .payment-form .form-field {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }
    .payment-form .form-field label {
        font-weight: 600;
        font-size: 0.85rem;
    }
    .payment-form .form-field input,
    .payment-form .form-field select {
        padding: 0.6rem;
        border-radius: 0.75rem;
        border: 1px solid var(--border);
        background: var(--surface-alt);
        font-size: 0.95rem;
    }
    .payment-form .submit-btn {
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 2rem;
        padding: 0.75rem;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    /* Pending Records Table (compact) */
    .pending-records {
        background: var(--surface);
        border-radius: 1.5rem;
        padding: 1rem;
        border: 1px solid var(--border);
        margin-bottom: 1rem;
    }
    .pending-records h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1rem;
    }
    .pending-records .record-row {
        display: flex;
        justify-content: space-between;
        padding: 0.4rem 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.85rem;
    }
    .pending-records .record-row:last-child {
        border-bottom: none;
    }
    .pending-records .record-row .remaining {
        font-weight: 700;
        color: var(--danger);
    }
    .pending-records .total-row {
        font-weight: 700;
        padding-top: 0.5rem;
        border-top: 2px solid var(--border);
        margin-top: 0.3rem;
    }

    /* Action Buttons (generate) */
    .action-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin: 0.5rem 0 1rem;
    }
    .action-row button {
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .action-row button.primary {
        background: var(--primary);
        color: white;
        border: none;
    }

    /* Back link */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    /* Pagination */
    .pagination {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1rem;
        flex-wrap: wrap;
    }
    .pagination a, .pagination span {
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface);
        text-decoration: none;
        color: var(--text);
        font-size: 0.8rem;
    }
    .pagination .current {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .empty-state {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--muted);
    }
    .empty-state .icon {
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    /* Toast for feedback */
    .toast {
        position: fixed;
        bottom: 80px;
        left: 50%;
        transform: translateX(-50%);
        background: #333;
        color: white;
        padding: 0.5rem 1.2rem;
        border-radius: 2rem;
        z-index: 999;
        display: none;
        font-size: 0.9rem;
        max-width: 90%;
        text-align: center;
    }
    .toast.success { background: #10b981; }
    .toast.error { background: #ef4444; }
</style>
{% endblock %}

{% block body %}
<!-- ======== TOAST ======== -->
<div id="toast" class="toast"></div>

<!-- ======== HEADER ======== -->
<div class="fee-header">
    <h1>Fee Collection</h1>
    <div class="header-stats">
        <span>Pending: <strong>₹{{ total_pending_all|default:0|floatformat:2 }}</strong></span>
    </div>
</div>

<!-- ======== LIST VIEW (no student selected) ======== -->
{% if not selected_student %}
    <!-- Search & Filters -->
    <form method="get" class="search-bar">
        <input type="search" name="pending_search" placeholder="Search name or roll" value="{{ search_filter|default:'' }}">
        <button type="submit">Go</button>
    </form>
    <div class="filter-chips">
        <select name="pending_grade" onchange="this.form.submit()">
            <option value="">All Grades</option>
            {% for g in grades %}
            <option value="{{ g }}" {% if grade_filter == g %}selected{% endif %}>{{ g }}</option>
            {% endfor %}
        </select>
        <select name="pending_section" onchange="this.form.submit()">
            <option value="">All Sections</option>
            {% for s in sections %}
            <option value="{{ s }}" {% if section_filter == s %}selected{% endif %}>{{ s }}</option>
            {% endfor %}
        </select>
        {% if search_filter or grade_filter or section_filter %}
        <a href="{% url 'fee_collection' schema_name=tenant.schema_name %}" class="chip-clear">Clear</a>
        {% endif %}
    </div>

    <!-- Generate All Fees button -->
    <div class="action-row">
        <button id="generateAllBtn" class="primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Generate All Fees
        </button>
    </div>

    <!-- Student List -->
    {% if pending_students %}
        {% for s in pending_students %}
        <div class="student-item">
            <div class="info">
                <div class="name">{{ s.name }}</div>
                <div class="meta">{{ s.grade }} - {{ s.section }} • Roll {{ s.roll_number }}</div>
                <div class="pending">₹{{ s.pending_total|floatformat:2 }}</div>
            </div>
            <a href="{% url 'fee_collection' schema_name=tenant.schema_name student_id=s.id %}" class="collect-btn">Collect</a>
        </div>
        {% endfor %}

        <!-- Pagination -->
        {% if pending_students.has_other_pages %}
        <div class="pagination">
            {% if pending_students.has_previous %}
                <a href="?page=1{% if search_filter %}&pending_search={{ search_filter }}{% endif %}{% if grade_filter %}&pending_grade={{ grade_filter }}{% endif %}{% if section_filter %}&pending_section={{ section_filter }}{% endif %}">&laquo; First</a>
                <a href="?page={{ pending_students.previous_page_number }}{% if search_filter %}&pending_search={{ search_filter }}{% endif %}{% if grade_filter %}&pending_grade={{ grade_filter }}{% endif %}{% if section_filter %}&pending_section={{ section_filter }}{% endif %}">Previous</a>
            {% endif %}
            <span class="current">Page {{ pending_students.number }} of {{ pending_students.paginator.num_pages }}</span>
            {% if pending_students.has_next %}
                <a href="?page={{ pending_students.next_page_number }}{% if search_filter %}&pending_search={{ search_filter }}{% endif %}{% if grade_filter %}&pending_grade={{ grade_filter }}{% endif %}{% if section_filter %}&pending_section={{ section_filter }}{% endif %}">Next</a>
                <a href="?page={{ pending_students.paginator.num_pages }}{% if search_filter %}&pending_search={{ search_filter }}{% endif %}{% if grade_filter %}&pending_grade={{ grade_filter }}{% endif %}{% if section_filter %}&pending_section={{ section_filter }}{% endif %}">Last &raquo;</a>
            {% endif %}
        </div>
        {% endif %}
    {% else %}
        <div class="empty-state">
            <div class="icon">📭</div>
            <p>No students with pending fees.</p>
            <p style="font-size:0.8rem;">Click <strong>“Generate All Fees”</strong> to create fee records for the current month.</p>
        </div>
    {% endif %}

    <!-- Recent Payments (compact) -->
    <div style="margin-top:1.5rem;">
        <h3 style="font-size:1rem; margin-bottom:0.5rem;">Recent Payments</h3>
        {% if recent_payments %}
            {% for p in recent_payments %}
            <div class="student-item" style="padding:0.6rem 0.8rem;">
                <div class="info">
                    <div class="name">{{ p.student.name }}</div>
                    <div class="meta">{{ p.receipt_number }} • {{ p.payment_date|date:"d M Y" }}</div>
                </div>
                <div style="font-weight:700; color:var(--primary);">₹{{ p.amount|floatformat:2 }}</div>
            </div>
            {% endfor %}
        {% else %}
            <div class="empty-state" style="padding:1rem;">No recent payments</div>
        {% endif %}
    </div>

<!-- ======== DETAIL VIEW (student selected) ======== -->
{% else %}
    <!-- Back link -->
    <a href="{% url 'fee_collection' schema_name=tenant.schema_name %}" class="back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
        </svg>
        Back to list
    </a>

    <!-- Student Info -->
    <div class="student-detail-card">
        <div class="name-row">
            <h2>{{ selected_student.name }} <span class="roll">({{ selected_student.roll_number }})</span></h2>
            <span class="pending-total">₹{{ total_pending|floatformat:2 }}</span>
        </div>
        <div class="detail-meta">{{ selected_student.grade }} - {{ selected_student.section }} • Father: {{ selected_student.father_name }}</div>
    </div>

    <!-- Generate Current Month Fee -->
    <div class="action-row">
        <button id="generateSingleBtn" class="primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            Generate Current Month Fee
        </button>
    </div>

    <!-- Payment Form -->
    <form method="post" class="payment-form" id="paymentForm">
        {% csrf_token %}
        <input type="hidden" name="student_id" value="{{ selected_student.id }}">
        <input type="hidden" name="product_items_json" id="productItemsJson" value="[]">
        <div class="form-row">
            <div class="form-field">
                <label>Amount Received (₹)</label>
                <input type="number" name="amount" id="amountInput" step="0.01" required placeholder="Enter amount">
            </div>
            <div class="form-field">
                <label>Payment Mode</label>
                <select name="payment_mode">
                    <option value="cash">Cash</option>
                    <option value="bank_transfer">Bank Transfer</option>
                    <option value="cheque">Cheque</option>
                    <option value="online">Online</option>
                </select>
            </div>
            <div class="form-field">
                <label>Remaining after payment</label>
                <input type="text" id="remainingAfter" readonly placeholder="Will be calculated">
            </div>
            <button type="submit" class="submit-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/>
                </svg>
                Process Payment
            </button>
        </div>
    </form>

    <!-- Pending Records -->
    <div class="pending-records">
        <h4>Pending Fee Records</h4>
        {% if pending_records %}
            {% for r in pending_records %}
            <div class="record-row">
                <span>{{ r.month }}/{{ r.year }}</span>
                <span>₹{{ r.amount|floatformat:2 }}</span>
                <span>Paid: ₹{{ r.paid_amount|floatformat:2 }}</span>
                <span class="remaining">₹{{ r.remaining|floatformat:2 }}</span>
            </div>
            {% endfor %}
            <div class="record-row total-row">
                <span>Total Pending</span>
                <span></span>
                <span></span>
                <span class="remaining">₹{{ total_pending|floatformat:2 }}</span>
            </div>
        {% else %}
            <div class="empty-state" style="padding:0.5rem;">No pending fees.</div>
        {% endif %}
    </div>
{% endif %}

<!-- ======== SCRIPTS ======== -->
<script>
    const csrftoken = getCookie('csrftoken');
    const schema = '{{ tenant.schema_name }}';

    function getCookie(name) {
        let v = null;
        if (document.cookie && document.cookie !== '') {
            const cookies = document.cookie.split(';');
            for (let i = 0; i < cookies.length; i++) {
                const cookie = cookies[i].trim();
                if (cookie.substring(0, name.length + 1) === (name + '=')) {
                    v = decodeURIComponent(cookie.substring(name.length + 1));
                    break;
                }
            }
        }
        return v;
    }

    function showToast(msg, type='success') {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.className = 'toast ' + type;
        toast.style.display = 'block';
        setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }

    // ---- Generate All Fees ----
    const genAllBtn = document.getElementById('generateAllBtn');
    if (genAllBtn) {
        genAllBtn.addEventListener('click', async () => {
            if (!confirm('Generate fee records for current month for all active students?')) return;
            genAllBtn.disabled = true;
            genAllBtn.innerHTML = 'Generating...';
            try {
                const resp = await fetch('/api/manual-generate/', {
                    method: 'POST',
                    headers: { 'X-CSRFToken': csrftoken, 'Content-Type': 'application/json' },
                });
                const data = await resp.json();
                if (data.message) {
                    showToast(data.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else if (data.error) {
                    showToast('Error: ' + data.error, 'error');
                }
            } catch(e) {
                showToast('Error: ' + e.message, 'error');
            } finally {
                genAllBtn.disabled = false;
                genAllBtn.innerHTML = 'Generate All Fees';
            }
        });
    }

    // ---- Generate Single Fee ----
    const genSingleBtn = document.getElementById('generateSingleBtn');
    if (genSingleBtn) {
        genSingleBtn.addEventListener('click', async () => {
            const studentId = {{ selected_student.id|default:'null' }};
            if (!studentId) return;
            if (!confirm(`Generate current month fee for {{ selected_student.name }}?`)) return;
            genSingleBtn.disabled = true;
            genSingleBtn.innerHTML = 'Generating...';
            try {
                const resp = await fetch(`/api/manual-generate-single/?student_id=${studentId}`, {
                    method: 'POST',
                    headers: { 'X-CSRFToken': csrftoken, 'Content-Type': 'application/json' },
                });
                const data = await resp.json();
                if (data.message) {
                    showToast(data.message, 'success');
                    setTimeout(() => location.reload(), 1500);
                } else if (data.error) {
                    showToast('Error: ' + data.error, 'error');
                }
            } catch(e) {
                showToast('Error: ' + e.message, 'error');
            } finally {
                genSingleBtn.disabled = false;
                genSingleBtn.innerHTML = 'Generate Current Month Fee';
            }
        });
    }

    // ---- Remaining amount calculation ----
    const amountInput = document.getElementById('amountInput');
    const remainingSpan = document.getElementById('remainingAfter');
    const totalPending = parseFloat('{{ total_pending|default:0 }}');
    if (amountInput && remainingSpan) {
        amountInput.addEventListener('input', function() {
            const paid = parseFloat(this.value) || 0;
            const remaining = Math.max(totalPending - paid, 0);
            remainingSpan.value = '₹' + remaining.toFixed(2);
        });
        // trigger initially
        amountInput.dispatchEvent(new Event('input'));
    }

    // ---- Auto-submit filters on select change ----
    document.querySelectorAll('.filter-chips select').forEach(sel => {
        sel.addEventListener('change', function() {
            this.closest('form')?.submit();
        });
    });
</script>
{% endblock %}
