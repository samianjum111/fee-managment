{% extends 'tenant/base.html' %}
{% block title %}Gym Dashboard | {{ tenant.name }}{% endblock %}
{% block body %}
<div class="dashboard-header">
    <div><h1 class="page-title">Welcome to {{ tenant.name }}</h1><p class="page-desc">Gym Management Dashboard</p></div>
    {% if logo_url %}<img src="{{ logo_url }}" class="school-logo">{% endif %}
</div>
<div class="quick-actions">
    <a href="{% url 'gym_attendance' schema_name=tenant.schema_name %}" class="action-card"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span>Mark Attendance</span></a>
    <a href="{% url 'gym_customer_add' schema_name=tenant.schema_name %}" class="action-card"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg><span>Add Customer</span></a>
    <a href="{% url 'gym_payment' schema_name=tenant.schema_name %}" class="action-card"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg><span>Collect Payment</span></a>
    <a href="{% url 'gym_reports' schema_name=tenant.schema_name %}" class="action-card"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><span>Reports</span></a>
</div>
<div class="kpi-grid">
    <div class="kpi-card"><div class="kpi-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg></div><div class="kpi-info"><span class="kpi-label">Today's Check-ins</span><span class="kpi-value">{{ today_checkins }}</span><span class="kpi-trend">{{ today|date:"d M Y" }}</span></div></div>
    <div class="kpi-card"><div class="kpi-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div><div class="kpi-info"><span class="kpi-label">Active Customers</span><span class="kpi-value">{{ active_customers }}</span><span class="kpi-trend">Currently enrolled</span></div></div>
    <div class="kpi-card"><div class="kpi-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 12h3l3-9 3 18 3-9h3"/></svg></div><div class="kpi-info"><span class="kpi-label">Revenue (This Month)</span><span class="kpi-value">₹{{ month_revenue|floatformat:2 }}</span><span class="kpi-trend">{{ today|date:"F Y" }}</span></div></div>
    <div class="kpi-card"><div class="kpi-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div class="kpi-info"><span class="kpi-label">Expiring Soon</span><span class="kpi-value">{{ expiring_soon }}</span><span class="kpi-trend">Next 7 days</span></div></div>
</div>
<div class="dashboard-grid"><div class="card"><div class="card-header"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg><h3>Recent Payments</h3><a href="{% url 'gym_reports' schema_name=tenant.schema_name %}?type=revenue" class="view-link">View all →</a></div><div class="table-responsive"><table class="data-table"><thead><tr><th>Receipt</th><th>Customer</th><th>Amount</th><th>Date</th><th>Mode</th></tr></thead><tbody>{% for p in recent_payments %}<tr><td><code>{{ p.receipt_number }}</code></td><td>{{ p.customer.name }}</td><td class="amount">₹{{ p.amount|floatformat:2 }}</td><td>{{ p.payment_date|date:"d M Y" }}</td><td>{{ p.get_payment_mode_display }}</td></tr>{% empty %}<tr><td colspan="5" class="empty-row">No payments recorded yet</td></tr>{% endfor %}</tbody></table></div></div>
<div class="card"><div class="card-header"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 3v18h18"/><path d="M18 17V9M12 17V5M6 17v-3"/></svg><h3>Monthly Revenue Trend</h3></div><canvas id="revenueChart" height="200"></canvas></div></div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>const months = {{ months_labels|safe }}; const amounts = {{ months_amounts|safe }}; new Chart(document.getElementById('revenueChart'), { type: 'line', data: { labels: months, datasets: [{ label: 'Revenue (₹)', data: amounts, borderColor: '#3b82f6', fill: true }] } });</script>
{% endblock %}